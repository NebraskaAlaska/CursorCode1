# Virtual environments
.venv/
venv/
env/

# Generated artifacts (re-creatable from raw data via the scripts)
data/processed/
reports/figures/
outputs/figures/
outputs/tables/

# Real / generated measured-experimental data — do NOT commit by default.
# These are research data (confidential) or re-creatable run sheets. The ONLY
# file kept tracked in this folder is the blank template (re-included below).
# (Comments must be on their own line — an inline '#' is part of the pattern.)
data/raw/experimental_icp/monday_experiment_plan.csv
data/raw/experimental_icp/experimental_release_manual_entry.csv
# any measured release/measured CSV; dated lab files like 2026-06-01_release_run2.csv
data/raw/experimental_icp/*release*.csv
data/raw/experimental_icp/20*_release*.csv
data/raw/experimental_icp/*measured*.csv
# Keep the blank template tracked (it matches *release*.csv above, so re-include it).
!data/raw/experimental_icp/experimental_release_template.csv

