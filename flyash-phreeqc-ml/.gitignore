# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Generated artifacts (re-creatable from raw data via the scripts)
data/processed/
reports/figures/
outputs/figures/
outputs/tables/
# Simulate-tab deterministic PHREEQC execution workspace — generated .pqi/.pqo/.sel
# inputs and outputs are simulation artifacts, never committed.
outputs/simulations/

# Real / generated measured-experimental data — do NOT commit by default.
# These are research data (confidential) or re-creatable run sheets. The ONLY
# file kept tracked in this folder is the blank template (re-included below).
# (Comments must be on their own line — an inline '#' is part of the pattern.)
data/raw/experimental_icp/experiment_plan.csv
data/raw/experimental_icp/experimental_release_manual_entry.csv
# generated sample_id -> PHREEQC record_key mapping (links measured data; keep out of git)
data/raw/experimental_icp/sample_phreeqc_map.csv
# any measured release/measured CSV; dated lab files like 2026-06-01_release_run2.csv
data/raw/experimental_icp/*release*.csv
data/raw/experimental_icp/20*_release*.csv
data/raw/experimental_icp/*measured*.csv
# Keep the blank template tracked (it matches *release*.csv above, so re-include it).
!data/raw/experimental_icp/experimental_release_template.csv

# Mix-design / ICP workbooks (CFA+MK design). Confidential research data — ignore
# any spreadsheet here by default so a *new* ICP file is never committed accidentally.
# The one approved, already-tracked UMass workbook is re-included below (it is allowed
# in this private repo); add other files only with data-owner sign-off.
data/raw/icp_mix_design/*.xlsx
data/raw/icp_mix_design/*.xls
data/raw/icp_mix_design/*.csv
!data/raw/icp_mix_design/CFA + MK design mix_UMass.xlsx

# Experiment-run "save files" — run data and outputs are research data or
# generated artifacts; do NOT commit by default. Only experiments/README.md is
# tracked. (Comments must be on their own line — an inline '#' is part of the pattern.)
experiments/*/data/*.csv
experiments/*/outputs/
experiments/*/run_config.yaml

# OS / editor cruft
.DS_Store
.idea/
.vscode/
